# Copy this file to .env for local development.
# Do not commit real credentials.

# Search provider selection for local runs.
# Default runtime path is victoria. Set mock only for fixture-based CLI checks.
OBSH_SEARCH_PROVIDER=victoria

# Optional path to victoriaq binary when not in PATH.
# OBSH_VICTORIAQ_BIN=/root/.openclaw/workspace/bin/victoriaq

# Placeholder endpoints for future Victoria providers.
VICTORIA_LOGS_URL=http://127.0.0.1:9428
VICTORIA_METRICS_URL=http://127.0.0.1:8428
VICTORIA_TRACES_URL=http://127.0.0.1:10428

# Example auth header key names only; values must come from local env.
# VICTORIA_API_TOKEN=
